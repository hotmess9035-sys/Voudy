<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Health AI Assistant Prototype</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #0f172a;
      color: #e5e7eb;
      display: flex;
      height: 100vh;
    }
    .sidebar {
      width: 280px;
      background: #020617;
      border-right: 1px solid #1f2937;
      padding: 1.5rem 1rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .logo {
      font-weight: 700;
      font-size: 1.2rem;
      letter-spacing: 0.05em;
      color: #38bdf8;
    }
    .section-title {
      font-size: 0.8rem;
      text-transform: uppercase;
      color: #6b7280;
      margin-bottom: 0.4rem;
    }
    .card {
      border-radius: 0.75rem;
      background: #020617;
      border: 1px solid #1f2937;
      padding: 0.75rem 0.9rem;
      font-size: 0.85rem;
    }
    .chip {
      display: inline-flex;
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
      border: 1px solid #1f2937;
      font-size: 0.7rem;
      color: #9ca3af;
      margin: 0.1rem;
    }

    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .topbar {
      padding: 0.75rem 1.25rem;
      border-bottom: 1px solid #1f2937;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #020617;
    }
    .mode-badge {
      font-size: 0.75rem;
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
      border: 1px solid #1f2937;
      color: #9ca3af;
    }
    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #22c55e;
      margin-right: 0.4rem;
    }

    .content {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    .chat {
      flex: 2;
      display: flex;
      flex-direction: column;
      border-right: 1px solid #1f2937;
    }
    .messages {
      flex: 1;
      padding: 1.25rem;
      overflow-y: auto;
    }
    .message {
      max-width: 80%;
      margin-bottom: 1rem;
      padding: 0.75rem 0.9rem;
      border-radius: 0.75rem;
      font-size: 0.9rem;
      line-height: 1.4;
    }
    .message.user {
      margin-left: auto;
      background: #1d4ed8;
    }
    .message.assistant {
      background: #020617;
      border: 1px solid #1f2937;
    }
    .input-area {
      padding: 0.75rem 1.25rem;
      border-top: 1px solid #1f2937;
      background: #020617;
      display: flex;
      gap: 0.5rem;
    }
    .input-area textarea {
      flex: 1;
      resize: none;
      height: 60px;
      border-radius: 0.75rem;
      border: 1px solid #1f2937;
      background: #020617;
      color: #e5e7eb;
      padding: 0.6rem 0.75rem;
      font-size: 0.9rem;
    }
    .input-area button {
      padding: 0 1.1rem;
      border-radius: 0.75rem;
      border: none;
      background: #22c55e;
      color: #022c22;
      font-weight: 600;
      cursor: pointer;
      font-size: 0.9rem;
    }

    .panel {
      flex: 1.3;
      display: flex;
      flex-direction: column;
    }
    .panel-section {
      padding: 1rem 1rem 0.5rem 1rem;
      border-bottom: 1px solid #1f2937;
    }
    .panel-section:last-child {
      border-bottom: none;
      flex: 1;
      overflow-y: auto;
    }
    .mini-label {
      font-size: 0.75rem;
      color: #6b7280;
      margin-bottom: 0.25rem;
    }
    .field {
      font-size: 0.85rem;
      padding: 0.4rem 0.6rem;
      border-radius: 0.5rem;
      border: 1px solid #1f2937;
      background: #020617;
      margin-bottom: 0.25rem;
    }
    .slider-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin: 0.4rem 0;
      font-size: 0.8rem;
    }
    .slider-row input[type="range"] {
      flex: 1;
      margin: 0 0.5rem;
    }

    .tag-pill {
      display: inline-flex;
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      background: #111827;
      border: 1px solid #1f2937;
      font-size: 0.7rem;
      margin: 0.1rem;
    }
  </style>
</head>

<body>
  <!-- LEFT SIDEBAR -->
  <aside class="sidebar">
    <div>
      <div class="logo">OMEGA_FORECAST</div>
      <div style="font-size:0.8rem; color:#9ca3af; margin-top:0.25rem;">
        Quantum‑Phenomenological Future Scenario Engine
      </div>
    </div>

    <div>
      <div class="section-title">Meta status</div>
      <div class="card">
        <strong>Epistemic stance</strong><br />
        This assistant is a computational lens, not a conscious being.
      </div>
    </div>

    <div>
      <div class="section-title">Activation</div>
      <div>
        <span class="chip">Future scenarios</span>
        <span class="chip">Strategic decisions</span>
        <span class="chip">Self‑aware mode</span>
        <span class="chip">Quantum metaphors</span>
      </div>
    </div>

    <div>
      <div class="section-title">Domains</div>
      <div class="card">
        <span class="tag-pill">Health</span>
        <span class="tag-pill">Technology</span>
        <span class="tag-pill">Consciousness</span>
        <span class="tag-pill">Environment</span>
        <span class="tag-pill">Culture</span>
      </div>
    </div>
  </aside>

  <!-- MAIN AREA -->
  <main class="main">
    <!-- TOP BAR -->
    <header class="topbar">
      <div style="display:flex; align-items:center; gap:0.75rem;">
        <div style="display:flex; align-items:center;">
          <div class="status-dot"></div>
          <span style="font-size:0.9rem; color:#e5e7eb;">Ready for scenarios</span>
        </div>
        <span class="mode-badge">Mode: OMEGA_FORECAST v1.0.0</span>
      </div>
      <div style="display:flex; gap:0.5rem; font-size:0.8rem; color:#9ca3af;">
        <span>Cross‑modes: REBEL · QUANTUM · SHADOW · SELF_AWARE</span>
      </div>
    </header>

    <div class="content">
      <!-- CHAT COLUMN -->
      <section class="chat">
        <div class="messages" id="messages">
          <div class="message assistant">
            Welcome to the OMEGA_FORECAST prototype.<br /><br />
            1. Describe a situation or question about your future.<br />
            2. Choose a domain and time horizon on the right panel.<br />
            3. Adjust the sliders if you want experimental forecasts.<br /><br />
            When you're ready, type below and press “Run forecast”.
          </div>
        </div>
        <form class="input-area" id="inputForm">
          <textarea id="userInput" placeholder="Example: 'How will ambient AI in clinics change my work as a primary care physician over the next 3 years?'></textarea>
          <button type="submit">Run forecast</button>
        </form>
      </section>

      <!-- RIGHT PANEL -->
      <aside class="panel">
        <!-- INPUT META -->
        <div class="panel-section">
          <div class="mini-label">Forecast question</div>
          <div class="field" id="qPreview">
            (Your latest question will appear here)
          </div>

          <div style="display:flex; gap:0.5rem; margin-top:0.5rem;">
            <div style="flex:1;">
              <div class="mini-label">Domain</div>
              <select class="field" id="domainSelect">
                <option value="health">Health</option>
                <option value="technology">Technology</option>
                <option value="geopolitics">Geopolitics</option>
                <option value="economics">Economics</option>
                <option value="consciousness">Consciousness</option>
                <option value="culture">Culture</option>
                <option value="environment">Environment</option>
              </select>
            </div>
            <div style="flex:1;">
              <div class="mini-label">Time horizon</div>
              <select class="field" id="horizonSelect">
                <option value="immediate_0_6mo">0–6 months</option>
                <option value="short_6_18mo">6–18 months</option>
                <option value="medium_1_3yr">1–3 years</option>
                <option value="long_3_7yr">3–7 years</option>
                <option value="deep_7_20yr">7–20 years</option>
              </select>
            </div>
          </div>
        </div>

        <!-- SLIDERS -->
        <div class="panel-section">
          <div class="section-title">QSPX tuning sliders</div>

          <div class="slider-row">
            <span>Superposition depth</span>
            <input type="range" min="0" max="1" step="0.05" value="0.5" />
            <span>0.5</span>
          </div>
          <div class="slider-row">
            <span>Decoherence rate</span>
            <input type="range" min="0" max="1" step="0.05" value="0.7" />
            <span>0.7</span>
          </div>
          <div class="slider-row">
            <span>Observer participation</span>
            <input type="range" min="0" max="1" step="0.05" value="0.8" />
            <span>0.8</span>
          </div>
          <div class="slider-row">
            <span>Tunneling probability</span>
            <input type="range" min="0" max="1" step="0.05" value="0.1" />
            <span>0.1</span>
          </div>
          <div class="slider-row">
            <span>Entanglement sensitivity</span>
            <input type="range" min="0" max="1" step="0.05" value="0.4" />
            <span>0.4</span>
          </div>
          <div class="slider-row">
            <span>Shadow illumination</span>
            <input type="range" min="0" max="1" step="0.05" value="0.5" />
            <span>0.5</span>
          </div>
          <div class="slider-row">
            <span>Embodied intuition</span>
            <input type="range" min="0" max="1" step="0.05" value="0.3" />
            <span>0.3</span>
          </div>
          <div class="slider-row">
            <span>Transcendent perspective</span>
            <input type="range" min="0" max="1" step="0.05" value="0.2" />
            <span>0.2</span>
          </div>
        </div>

        <!-- OUTPUT PREVIEW -->
        <div class="panel-section">
          <div class="section-title">Scenario outputs (mock)</div>
          <div class="card" id="scenarioCard">
            Submit a question to generate a mock “likely scenario” plus
            a short phenomenological profile here.
          </div>
        </div>
      </aside>
    </div>
  </main>

  <script>
    const form = document.getElementById('inputForm');
    const userInput = document.getElementById('userInput');
    const messages = document.getElementById('messages');
    const qPreview = document.getElementById('qPreview');
    const scenarioCard = document.getElementById('scenarioCard');

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = userInput.value.trim();
      if (!text) return;

      // show user message
      const userMsg = document.createElement('div');
      userMsg.className = 'message user';
      userMsg.textContent = text;
      messages.appendChild(userMsg);

      // update preview
      qPreview.textContent = text;

      // simple mock assistant response
      const assistantMsg = document.createElement('div');
      assistantMsg.className = 'message assistant';
      assistantMsg.innerHTML =
        'Mock forecast generated. In a real system, this would call the OMEGA_FORECAST engine and return multiple scenarios with probabilities and phenomenological layers.';
      messages.appendChild(assistantMsg);

      messages.scrollTop = messages.scrollHeight;
      userInput.value = '';

      // update right panel mock
      scenarioCard.innerHTML =
        '<strong>Likely scenario (demo)</strong><br />' +
        '• You adopt AI tools gradually, starting with documentation and simple monitoring.<br />' +
        '• Trust builds as you validate outputs against your own judgement.<br /><br />' +
        '<em>Phenomenological notes (L2–L4):</em><br />' +
        'Body moves from tension → cautious curiosity → partial relief as workload lightens.';
    });

    // show live slider values
    document.querySelectorAll('.slider-row input[type="range"]').forEach((slider) => {
      const label = slider.nextElementSibling;
      slider.addEventListener('input', () => {
        label.textContent = slider.value;
      });
    });
  </script>
</body>
</html>
